{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Video Converter",
  "version": "0.1.0",
  "identifier": "com.localvideoconverter.app",
  "build": {
    "beforeDevCommand": "NEXT_DIST_DIR=.next-tauri next dev --port 5211",
    "devUrl": "http://localhost:5211",
    "beforeBuildCommand": "npm run build:desktop",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Local Video Converter",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Visible",
        "backgroundColor": "#07070b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      }
    },
    "externalBin": ["binaries/ffmpeg"],
    "category": "Video"
  }
}
