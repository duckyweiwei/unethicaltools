# ============================================================================
# unethicaltools — environment variables (template)
#
# 1. Copy this file to `.env.local`  →  `cp .env.example .env.local`
#    (`.env.local` is git-ignored; this template is safe to commit.)
# 2. Fill in the real values (see SETUP runbook for where each one comes from).
# 3. In production, set the SAME keys in:
#       Vercel → Project → Settings → Environment Variables
#
# Rules of thumb:
#   • NEVER commit real secrets. Only this placeholder template is committed.
#   • Anything prefixed NEXT_PUBLIC_ is shipped to the browser ON PURPOSE —
#     put ONLY publishable / non-secret values there.
#   • Everything else is server-only and never reaches the client bundle.
# ============================================================================

# ---- Site ------------------------------------------------------------------
# Canonical base URL, no trailing slash. Used for absolute links and as the
# fallback origin for Stripe checkout success/cancel redirects.
NEXT_PUBLIC_SITE_URL=https://unethicaltools.com

# ---- Auth.js (NextAuth v5) · Google sign-in --------------------------------
# Google Cloud Console → APIs & Services → Credentials → "OAuth client ID"
# (Application type: Web application). Runbook step 1.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Encrypts the session cookie. Generate a fresh 32-byte secret with:
#     openssl rand -base64 32      (or:  npx auth secret)
AUTH_SECRET=
# Only needed for non-Vercel / preview deploys. Vercel sets this for you.
# AUTH_URL=https://unethicaltools.com

# ---- Database · Auth.js adapter store + entitlement table ------------------
# Postgres connection string.
#   • Supabase:        Project → Settings → Database → Connection string (URI)
#   • Vercel Postgres: Storage → (your DB) → ".env.local" tab → POSTGRES_URL
DATABASE_URL=

# ---- Stripe · payments -----------------------------------------------------
# Dashboard → Developers → API keys.
# SECRET key — server-only, never exposed to the browser.
STRIPE_SECRET_KEY=
# PUBLISHABLE key — browser-safe. The ONLY Stripe key allowed to be public.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# The Price for your paid tier: Dashboard → Product catalog → (product) → Pricing.
# Looks like  price_1Q...
STRIPE_PRICE_ID=
# OPTIONAL second Price for an annual plan on the same product. When set, the
# upgrade screen shows a Monthly/Yearly toggle; leave blank for monthly-only.
STRIPE_PRICE_ID_YEARLY=
# "subscription" for a recurring Price, "payment" for a one-time Price.
STRIPE_MODE=subscription
# Webhook signing secret (whsec_…): Developers → Webhooks → (endpoint) →
# "Signing secret". Local testing: the Stripe CLI prints one on `stripe listen`.
STRIPE_WEBHOOK_SECRET=

# ---- AI layer (the paid features) -----------------------------------------
# The AI layer is provider-swappable behind one interface (lib/llm/client.ts).
# Set ONE provider key below. When neither is set the layer degrades quietly:
# /api/ai/config reports { configured: false }, the "Solve with AI" action is
# hidden, and /api/ai/solve answers 503 — nothing else changes. NEVER public.
#
# Gemini (the active provider — set this one):
#   aistudio.google.com → "Get API key" → Create API key.
GEMINI_API_KEY=
# Anthropic (alternative provider; leave blank unless you switch to Claude):
#   console.anthropic.com → Settings → API keys → "Create Key".
ANTHROPIC_API_KEY=
# OPTIONAL. Force a provider when more than one key is set. "gemini" or
# "anthropic". Unset → Gemini is preferred, then Anthropic.
# AI_PROVIDER=gemini
#
# OPTIONAL model overrides. Each AI feature routes to a sensible default model
# per provider in code; set any of these to pin/upgrade a model WITHOUT a code
# change as providers rename or reprice. Override values are used verbatim (so
# one env can point a feature at any provider's model id). Leave blank to use
# the built-in defaults.
#   AI_MODEL_DEFAULT overrides EVERY feature at once.
# AI_MODEL_DEFAULT=
#   Per-feature overrides (take precedence over the default for that one feature):
# AI_MODEL_SOLVE=        # answer-solving for keyless papers (default gemini-2.5-flash)
# AI_MODEL_EXPLAIN=      # answer explanations (coming soon)
# AI_MODEL_TUTOR=        # tutor (coming soon)
# AI_MODEL_GENERATE=     # question generation (coming soon)
# AI_MODEL_REPAIR=       # structured-JSON parse repair
